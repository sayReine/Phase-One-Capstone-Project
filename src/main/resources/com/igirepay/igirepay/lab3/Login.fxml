<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<StackPane style="-fx-background-color: linear-gradient(to bottom right, #0f3d1e, #1a5c2e, #236b38);"
           xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="lab3.LoginController">
    <VBox style="-fx-background-color: white; -fx-background-radius: 16; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.25), 30, 0, 0, 8); -fx-padding: 40 36; -fx-max-width: 360px;"
          spacing="0" alignment="CENTER" maxWidth="360">
        <VBox alignment="CENTER" spacing="4" style="-fx-padding: 0 0 28 0;">
            <Label text="IRO" style="-fx-font-size: 42px; -fx-font-weight: bold; -fx-text-fill: #c8860a;"/>
            <Label text="IgirePay" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1a3a2a;"/>
            <Label text="Secure Digital Wallet · Rwanda" style="-fx-font-size: 13px; -fx-text-fill: #7a9a8a;"/>
        </VBox>
        <Separator/>
        <VBox spacing="16" style="-fx-padding: 20 0 0 0;">
            <VBox spacing="4">
                <Label text="Phone Number" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #4a6a5a; -fx-padding: 0 0 3 2;"/>
                <TextField fx:id="phoneField" promptText="e.g. 0781234567"
                           style="-fx-background-color: #f8faf9; -fx-border-color: #d0e0d8; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 10 14; -fx-font-size: 13px; -fx-pref-height: 42px;"
                           maxWidth="Infinity"/>
            </VBox>
            <VBox spacing="4">
                <Label text="PIN" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #4a6a5a; -fx-padding: 0 0 3 2;"/>
                <PasswordField fx:id="pinField" promptText="Enter your 5-digit PIN"
                               style="-fx-background-color: #f8faf9; -fx-border-color: #d0e0d8; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 10 14; -fx-font-size: 13px; -fx-pref-height: 42px;"
                               maxWidth="Infinity"/>
            </VBox>
            <Label fx:id="statusLabel" text="" style="-fx-text-fill: #c0392b; -fx-font-size: 12px; -fx-font-weight: bold;" wrapText="true" maxWidth="Infinity"/>
            <VBox spacing="10" style="-fx-padding: 8 0 0 0;">
                <Button text="LOGIN" onAction="#handleLogin" maxWidth="Infinity"
                        style="-fx-background-color: #1a5c2e; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand; -fx-pref-height: 44px;"/>
                <HBox spacing="10">
                    <Button text="REGISTER" onAction="#handleRegister" maxWidth="Infinity" HBox.hgrow="ALWAYS"
                            style="-fx-background-color: transparent; -fx-text-fill: #1a5c2e; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 8; -fx-border-color: #1a5c2e; -fx-border-radius: 8; -fx-border-width: 1.5; -fx-cursor: hand; -fx-pref-height: 40px;"/>
                    <Button text="EXIT" onAction="#handleExit" maxWidth="Infinity" HBox.hgrow="ALWAYS"
                            style="-fx-background-color: #8b1a1a; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand; -fx-pref-height: 40px;"/>
                </HBox>
            </VBox>
        </VBox>
        <Label text="© 2025 IgirePay · Igire Rwanda Organization"
               style="-fx-font-size: 10px; -fx-text-fill: #aaaaaa; -fx-padding: 20 0 0 0;"/>
    </VBox>
</StackPane>