
<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox styleClass="root" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="lab3.DashboardController">

    <!-- Top Header - Bold Green -->
    <VBox style="-fx-background-color: #008000; -fx-padding: 20;" alignment="CENTER">
        <Label text="DASHBOARD" textFill="white" style="-fx-font-size: 24; -fx-font-weight: bold;"/>
        <Label fx:id="welcomeLabel" text="Welcome, Customer" textFill="#ff8c00" style="-fx-font-size: 16;"/>
    </VBox>

    <!-- Menu Options Grid -->
    <GridPane hgap="20" vgap="20" alignment="CENTER" VBox.vgrow="ALWAYS">
        <padding>
            <Insets top="30" bottom="30" left="30" right="30"/>
        </padding>

        <!-- Row 1 -->
        <VBox styleClass="card" spacing="15" alignment="CENTER" GridPane.columnIndex="0" GridPane.rowIndex="0" prefWidth="200" prefHeight="180">
            <Label text="ACCOUNTS" style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #008000;"/>
            <Button text="Create Wallet" styleClass="btn-primary" onAction="#createWallet" maxWidth="180"/>
            <Button text="Create Savings" styleClass="btn-primary" onAction="#createSavings" maxWidth="180"/>
            <Button text="View Balance" styleClass="btn-accent" onAction="#viewBalance" maxWidth="180"/>
        </VBox>

        <VBox styleClass="card" spacing="15" alignment="CENTER" GridPane.columnIndex="1" GridPane.rowIndex="0" prefWidth="200" prefHeight="180">
            <Label text="TRANSACTIONS" style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #008000;"/>
            <Button text="Deposit" styleClass="btn-primary" onAction="#deposit" maxWidth="180"/>
            <Button text="Withdraw" styleClass="btn-primary" onAction="#withdraw" maxWidth="180"/>
            <Button text="Transfer" styleClass="btn-accent" onAction="#transfer" maxWidth="180"/>
        </VBox>

        <!-- Row 2 -->
        <VBox styleClass="card" spacing="15" alignment="CENTER" GridPane.columnIndex="0" GridPane.rowIndex="1" prefWidth="200" prefHeight="180">
            <Label text="REPORTS" style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #008000;"/>
            <Button text="Transaction History" styleClass="btn-primary" onAction="#viewHistory" maxWidth="180"/>
            <Button text="Daily Summary" styleClass="btn-primary" onAction="#dailySummary" maxWidth="180"/>
            <Button text="Statement (7 days)" styleClass="btn-accent" onAction="#customerStatement" maxWidth="180"/>

        </VBox>

        <VBox styleClass="card" spacing="15" alignment="CENTER" GridPane.columnIndex="1" GridPane.rowIndex="1" prefWidth="200" prefHeight="180">
            <Label text="SETTINGS" style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #008000;"/>
            <Button text="Change PIN" styleClass="btn-primary" onAction="#changePIN" maxWidth="180"/>
            <Button text="Delete Account" styleClass="btn-primary" onAction="#deleteAccount" maxWidth="180"/>
            <Button text="Logout" styleClass="btn-accent" onAction="#logout" maxWidth="180"/>
        </VBox>
    </GridPane>

    <!-- Status Bar -->
    <HBox style="-fx-background-color: #333; -fx-padding: 10;" alignment="CENTER_LEFT">
        <Label fx:id="statusLabel" text="Ready" textFill="white"/>
    </HBox>
</VBox>

