<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="lab3.DashboardController"
            prefWidth="1000" prefHeight="680">
    <left>
        <VBox style="-fx-background-color: #0f3d1e; -fx-pref-width: 230px; -fx-min-width: 230px;" spacing="0">
            <VBox style="-fx-background-color: #081f0f; -fx-padding: 25 20 20 20;" alignment="CENTER" spacing="3">
                <Label text="IRO" style="-fx-font-size: 38px; -fx-font-weight: bold; -fx-text-fill: #c8860a;"/>
                <Label text="IgirePay" style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #7ab893;"/>
                <Label fx:id="welcomeLabel" text="Loading..." style="-fx-font-size: 11px; -fx-text-fill: #4a7a5a;"/>
            </VBox>
            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                        hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                        style="-fx-background: transparent; -fx-background-color: transparent;">
                <VBox spacing="3" style="-fx-padding: 16 10 10 10;">
                <Label text="MAIN" style="-fx-padding: 16 12 6 16; -fx-font-size: 10px; -fx-text-fill: #3a6a4a; -fx-font-weight: bold;"/>
                <Button text="🏠   Dashboard" onAction="#showHome" maxWidth="Infinity"
                        style="-fx-background-color: transparent; -fx-text-fill: #8abf9a; -fx-font-size: 13px; -fx-padding: 11 16; -fx-alignment: CENTER-LEFT; -fx-background-radius: 7; -fx-cursor: hand;"/>
                <Label text="ACCOUNTS" style="-fx-padding: 10 12 6 16; -fx-font-size: 10px; -fx-text-fill: #3a6a4a; -fx-font-weight: bold;"/>
                <Button text="💳   My Accounts" onAction="#showAccounts" maxWidth="Infinity"
                        style="-fx-background-color: transparent; -fx-text-fill: #8abf9a; -fx-font-size: 13px; -fx-padding: 11 16; -fx-alignment: CENTER-LEFT; -fx-background-radius: 7; -fx-cursor: hand;"/>
                <Button text="➕   Create Account" onAction="#showCreateAccount" maxWidth="Infinity"
                        style="-fx-background-color: transparent; -fx-text-fill: #8abf9a; -fx-font-size: 13px; -fx-padding: 11 16; -fx-alignment: CENTER-LEFT; -fx-background-radius: 7; -fx-cursor: hand;"/>
                <Label text="TRANSACTIONS" style="-fx-padding: 10 12 6 16; -fx-font-size: 10px; -fx-text-fill: #3a6a4a; -fx-font-weight: bold;"/>
                <Button text="⬆   Deposit"  onAction="#showDeposit"  maxWidth="Infinity"
                        style="-fx-background-color: transparent; -fx-text-fill: #8abf9a; -fx-font-size: 13px; -fx-padding: 11 16; -fx-alignment: CENTER-LEFT; -fx-background-radius: 7; -fx-cursor: hand;"/>
                <Button text="⬇   Withdraw" onAction="#showWithdraw" maxWidth="Infinity"
                        style="-fx-background-color: transparent; -fx-text-fill: #8abf9a; -fx-font-size: 13px; -fx-padding: 11 16; -fx-alignment: CENTER-LEFT; -fx-background-radius: 7; -fx-cursor: hand;"/>
                <Button text="↔   Transfer"  onAction="#showTransfer"  maxWidth="Infinity"
                        style="-fx-background-color: transparent; -fx-text-fill: #8abf9a; -fx-font-size: 13px; -fx-padding: 11 16; -fx-alignment: CENTER-LEFT; -fx-background-radius: 7; -fx-cursor: hand;"/>
                <Button text="📋   History"   onAction="#showHistory"   maxWidth="Infinity"
                        style="-fx-background-color: transparent; -fx-text-fill: #8abf9a; -fx-font-size: 13px; -fx-padding: 11 16; -fx-alignment: CENTER-LEFT; -fx-background-radius: 7; -fx-cursor: hand;"/>
                <Label text="REPORTS" style="-fx-padding: 10 12 6 16; -fx-font-size: 10px; -fx-text-fill: #3a6a4a; -fx-font-weight: bold;"/>
                <Button text="📊   Daily Summary"  onAction="#showDailySummary" maxWidth="Infinity"
                        style="-fx-background-color: transparent; -fx-text-fill: #8abf9a; -fx-font-size: 13px; -fx-padding: 11 16; -fx-alignment: CENTER-LEFT; -fx-background-radius: 7; -fx-cursor: hand;"/>
                <Button text="📄   Statement"       onAction="#showStatement"    maxWidth="Infinity"
                        style="-fx-background-color: transparent; -fx-text-fill: #8abf9a; -fx-font-size: 13px; -fx-padding: 11 16; -fx-alignment: CENTER-LEFT; -fx-background-radius: 7; -fx-cursor: hand;"/>
                <Button text="📁   Export CSV"      onAction="#exportCSV"        maxWidth="Infinity"
                        style="-fx-background-color: transparent; -fx-text-fill: #8abf9a; -fx-font-size: 13px; -fx-padding: 11 16; -fx-alignment: CENTER-LEFT; -fx-background-radius: 7; -fx-cursor: hand;"/>
                <Label text="SETTINGS" style="-fx-padding: 10 12 6 16; -fx-font-size: 10px; -fx-text-fill: #3a6a4a; -fx-font-weight: bold;"/>
                <Button text="💰   Request Loan" onAction="#showLoan" maxWidth="Infinity"
                        style="-fx-background-color: transparent; -fx-text-fill: #8abf9a; -fx-font-size: 13px; -fx-padding: 11 16; -fx-alignment: CENTER-LEFT; -fx-background-radius: 7; -fx-cursor: hand;"/>
                <Button text="🔑   Change PIN" onAction="#showChangePin" maxWidth="Infinity"
                        style="-fx-background-color: transparent; -fx-text-fill: #8abf9a; -fx-font-size: 13px; -fx-padding: 11 16; -fx-alignment: CENTER-LEFT; -fx-background-radius: 7; -fx-cursor: hand;"/>
                </VBox>
            </ScrollPane>
            <VBox style="-fx-padding: 10 10 16 10;">
                <Button text="🚪   Logout" onAction="#logout" maxWidth="Infinity"
                        style="-fx-background-color: #5c1a1a; -fx-text-fill: #ffaaaa; -fx-font-size: 13px; -fx-padding: 11 16; -fx-alignment: CENTER-LEFT; -fx-background-radius: 7; -fx-cursor: hand;"/>
            </VBox>
        </VBox>
    </left>
    <center>
        <VBox spacing="0">
            <HBox style="-fx-background-color: white; -fx-padding: 14 24; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 8, 0, 0, 2);" alignment="CENTER_LEFT" spacing="12">
                <Label fx:id="pageTitle" text="Dashboard" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1a3a2a;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="balanceBadge" text="Total: RWF 0.00"
                       style="-fx-background-color: #e8f5ec; -fx-text-fill: #1a5c2e; -fx-font-size: 12px; -fx-font-weight: bold; -fx-padding: 4 12; -fx-background-radius: 20;"/>
            </HBox>
            <ScrollPane fitToWidth="true"
                        VBox.vgrow="ALWAYS"
                        hbarPolicy="NEVER"
                        vbarPolicy="AS_NEEDED"
                        pannable="true"
                        style="-fx-background: #f0f4f1;">
            <content>
            <StackPane fx:id="contentPane" VBox.vgrow="ALWAYS"
                       style="-fx-background-color: #f0f4f1; -fx-padding: 24;"/>
            </content>

        </ScrollPane>
            <HBox style="-fx-background-color: #0f3d1e; -fx-padding: 10 20;" alignment="CENTER_LEFT">
                <Label fx:id="statusLabel" text="Ready"
                       style="-fx-text-fill: #7ab893; -fx-font-size: 12px;"/>
            </HBox>
        </VBox>
    </center>
</BorderPane>